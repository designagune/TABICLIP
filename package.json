{
  "name": "tabiclip",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "next dev",
    "dev:mock": "dotenv -e .env.example -- next dev",
    "build": "next build",
    "build:mock": "dotenv -e .env.example -- next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "dotenv -e .env.example -- playwright test",
    "test:db": "supabase test db",
    "storybook": "dotenv -e .env.example -- storybook dev -p 6006",
    "build-storybook": "dotenv -e .env.example -- storybook build",
    "check": "pnpm lint && pnpm typecheck && pnpm format:check && pnpm test:coverage && pnpm build"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@supabase/ssr": "0.12.3",
    "@supabase/supabase-js": "2.110.7",
    "@tanstack/react-query": "5.101.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.25.0",
    "next": "16.2.10",
    "next-intl": "4.13.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.82.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@storybook/addon-a11y": "10.5.3",
    "@storybook/addon-docs": "10.5.3",
    "@storybook/addon-vitest": "10.5.3",
    "@storybook/nextjs-vite": "10.5.3",
    "@tailwindcss/postcss": "4.3.3",
    "@testing-library/jest-dom": "7.0.0",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "axe-core": "4.12.1",
    "dotenv-cli": "11.0.0",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-storybook": "10.5.3",
    "jsdom": "29.1.1",
    "msw": "2.15.0",
    "msw-storybook-addon": "2.0.7",
    "prettier": "3.9.6",
    "prettier-plugin-tailwindcss": "0.8.1",
    "storybook": "10.5.3",
    "supabase": "^2.109.1",
    "tailwindcss": "4.3.3",
    "typescript": "5.9.3",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
